    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mongoose": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.0.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.0",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.0.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "helmet": "^8.0.0",
    "ioredis": "^5.3.2",
    "knex": "^3.1.0",
    "mongodb": "^6.5.0",
    "mongoose": "^8.3.0",
    "mysql2": "^3.9.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",

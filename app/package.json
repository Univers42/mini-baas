    "test:e2e": "jest --config ./test/jest-e2e.json --passWithNoTests"
  },
  "dependencies": {
    "@casl/ability": "^6.5.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",

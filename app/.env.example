# ============================================
# mini-baas — Environment Variables
# ============================================
# Copy this file to .env:    cp .env.example .env
# ⚠️ NEVER commit .env — it's in .gitignore

# ── Server ──
PORT=3000
NODE_ENV=development
CORS_ORIGINS=*
SWAGGER_ENABLED=true

# ── Control Plane (MongoDB) ──
MONGODB_URI=mongodb://baas-system-db:27117
MONGODB_DB_NAME=mini_baas_control

# ── Tenant Default DB (PostgreSQL - Phase 2) ──
# This is the default DB provisioned for new relational tenants in dev
TENANT_DB_HOST=baas-tenant-db
TENANT_DB_PORT=5432
TENANT_DB_USER=tenant_admin
TENANT_DB_PASSWORD=tenant_password

# ── Cache / Real-Time (Redis) ──
REDIS_HOST=baas-redis
REDIS_PORT=6379

# ── Security & Cryptography ──
# MASTER KEY: Used to encrypt per-tenant secrets (pepper, jwt secret) at rest.
# MUST BE 32 BYTES HEX. Generate with: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=replace_with_32_byte_hex_string_before_production

# ── Email (dev: Mailpit catches everything) ──
SMTP_HOST=baas-mailpit
SMTP_PORT=1025
SMTP_SECURE=false
EMAIL_FROM=noreply@minibaas.local

# ── File Uploads ──
UPLOAD_MAX_SIZE_MB=10

# ── API Rate Limiting ──
API_RATE_LIMIT_TTL=60
API_RATE_LIMIT_MAX=120

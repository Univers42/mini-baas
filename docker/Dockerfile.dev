# ============================================
# mini-baas — Development Engine
# ============================================
# Alpine-based Node.js 22 optimized for the Polyglot BaaS.
# Provides native build tools for bcrypt and isolated-vm.
# ============================================

FROM node:22-alpine

# ── System Dependencies ──────────────────────────────
# bash, make, curl      → dev tooling
# python3, g++          → native module compilation (isolated-vm, bcrypt)
# openssl, libc6-compat → crypto requirements
# postgresql-client     → psql for Phase 2 (SQL Shield) debugging
# redis                 → redis-cli for cache debugging
RUN apk add --no-cache \
    bash curl git jq make psmisc procps \
    python3 g++ \
    openssl libc6-compat \
    postgresql16-client \
    redis \
    file \
    shadow \
    && rm -rf /var/cache/apk/*

# ── Working Directory ────────────────────────────────
# Pointing directly to the new, clean DDD structure
WORKDIR /app/app

# ── Enable pnpm ──────────────────────────────────────
ENV PNPM_HOME="/pnpm" \
    PATH="/pnpm:$PATH"

# ── Global Tools ─────────────────────────────────────
# Removed Prisma. Kept NestJS CLI.
RUN corepack enable \
    && corepack prepare pnpm@latest --activate \
    && pnpm add -g \
        typescript@~5.7 \
        @nestjs/cli@~11 \
    && pnpm approve-builds -g

# ── Healthcheck ──────────────────────────────────────
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD node -e "process.exit(0)" || exit 1

# ── Entrypoint ───────────────────────────────────────
# Keep alive so 'make dev' can exec into it
CMD ["tail", "-f", "/dev/null"]

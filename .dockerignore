# ============================================
# mini-baas — Docker Build Context Exclusions
# ============================================

# ── Git ──
.git
.gitignore
.github

# ── Dependencies ──
**/node_modules
**/.npm
**/.pnpm-store

# ── Build artifacts ──
**/dist
**/build
**/.cache

# ── Environment & secrets ──
.env
.env.*
!.env.example

# ── IDE & editor ──
.vscode
.idea
**/.DS_Store
**/*.swp
**/*.swo
*~

# ── Testing artifacts ──
**/coverage
**/.nyc_output
**/test-results*

# ── Docker files ──
docker-compose*.yml
Dockerfile*

# ── OS junk ──
Thumbs.db
.DS_Store

# ── Uploads / data (dev only) ──
uploads/
data/
*.log
